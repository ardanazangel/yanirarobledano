# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# non-optimized source images
/public/imgs/**/*.jpg
/public/imgs/**/*.jpeg
/public/imgs/**/*.JPG
/public/imgs/**/*.JPEG
/public/imgs/**/*.png
/public/imgs/**/*.PNG
/public/imgs/**/*.heic
/public/imgs/**/*.HEIC
/public/imgs/**/*.tif
/public/imgs/**/*.tiff
/public/imgs/**/*.TIF
/public/imgs/**/*.TIFF

!public/imgs/imgs-inicio/
!public/imgs/imgs-inicio/**
